# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
.eggs/
build/
dist/

# uv
.uv/

# OS
.DS_Store
Thumbs.db

# Editors
.idea/
.vscode/
*.swp

# Data — real slips are PII, never commit raw images
data/real/
data/real_v*/
data/real_phone_v*/
data/synth_v*/
data/eval/images/
data/**/*.jpg
data/**/*.jpeg
data/**/*.png
# Allow label JSONLs, dataset yamls, and schema files to commit for auditing
!data/**/*.jsonl
!data/**/*.yaml
!data/**/schema.json
# …but gold-transcription JSONLs contain real reference IDs, names,
# account numbers — PII, re-exclude them.
data/eval/gold_*.jsonl

# Real slip images from scrape — PII, never commit. Provenance/labels do commit.
data/real_scrape/**/images/
data/real_scrape/**/*.jpg
data/real_scrape/**/*.jpeg
data/real_scrape/**/*.png
# Roboflow SDK download cache
.rf_cache/

# Streamlit cache
.streamlit/

# Model weights — regenerable from training
runs/
artifacts/
outputs/
*.safetensors
*.bin
*.gguf
checkpoints/
mlruns/
wandb/

# HF model cache redirects
.cache/
hf_cache/

# Generated reports
experiments/runs/
experiments/figures/samples/
# Label-preview renderings on real data — contain PII slips
experiments/figures/real_phone_v*_preview/
